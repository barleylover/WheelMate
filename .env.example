KAKAO_REST_API_KEY=
GOOGLE_MAPS_API_KEY=
PUBLIC_DATA_SERVICE_KEY=
KTO_SERVICE_KEY=
CULTURE_BIGDATA_API_KEY=

USE_GOOGLE_PLACES=true
# Google Places(유료, accessibilityOptions SKU)는 기본적으로 로컬 근거(Kakao/OSM/공공데이터)가
# 부족할 때만 fallback 으로 호출합니다. 매 요청마다 항상 호출하려면 false 로 두세요.
GOOGLE_FALLBACK_ONLY=true
USE_OSM=true
DEFAULT_RADIUS_M=1000
DEFAULT_LIMIT=3
DB_PATH=./data/accessibility.db

# 공공데이터 OpenAPI 적재 (pnpm run ingest:api) — data.go.kr 전국장애인편의시설표준데이터(B554287)
# 개발계정 100콜/일 제한이라 페이지/eval 수를 보수적으로 둔다.
PUBLIC_DATA_MAX_PAGES=3       # getDisConvFaclList 페이지 수
PUBLIC_DATA_NUM_ROWS=1000     # 페이지당 건수
PUBLIC_DATA_EVAL_LIMIT=0      # features(경사로/승강기/화장실) 채울 시설 수(eval 호출 수). 0=생략→일반 B등급
# PUBLIC_DATA_SIDO=서울특별시  # (선택) 주소 접두 필터(클라이언트측)

# Optional tuning
OVERPASS_API_URL=https://overpass-api.de/api/interpreter
HTTP_TIMEOUT_MS=8000
DEBUG=false
