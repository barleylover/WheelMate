# Recommended HTTP authentication mode. Set the same high-entropy value in the
# server environment and PlayMCP Key/token authentication.
MCP_ACCESS_TOKEN=

# Required for Kakao Local API and Daum Search API.
KAKAO_REST_API_KEY=

# Required for Naver Search API.
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Optional public data/API keys. These are included in the PlayMCP config token
# and can be used with imported public accessibility datasets.
PUBLIC_DATA_SERVICE_KEY=
KTO_SERVICE_KEY=
CULTURE_BIGDATA_API_KEY=

# High-level feature flags.
USE_NAVER_SEARCH=true
USE_DAUM_SEARCH=true
USE_REVIEW_SEARCH=true

# Per-source feature flags.
USE_NAVER_BLOG=true
USE_NAVER_CAFE=true
USE_NAVER_WEB=true
USE_DAUM_BLOG=true
USE_DAUM_CAFE=true
USE_DAUM_WEB=true

# Runtime limits.
DEFAULT_RADIUS_M=1000
DEFAULT_LIMIT=5
MAX_PLACE_CANDIDATES=15
MAX_REVIEW_SEARCH_CALLS=60
# Hard request-level budget across location, discovery, and review API calls.
# Retries also consume this budget.
MAX_EXTERNAL_API_CALLS_PER_REQUEST=40
SEARCH_RESULTS_PER_QUERY=3
SEARCH_TIMEOUT_MS=3500

# HTTP deployment settings.
PORT=8080
HOST=0.0.0.0
# Required for public deployment: comma-separated host allow-list.
# Example: MCP_ALLOWED_HOSTS=your-service.example.com,localhost
MCP_ALLOWED_HOSTS=

# If the deployment platform cannot inject environment variables, run
# `pnpm run token:playmcp` locally and paste the generated credential bundle
# into PlayMCP Key/token authentication instead. This fallback token is
# base64-encoded, not encrypted, so protect it exactly like the API keys.

# SQLite stores public/support data and geocoding cache only.
# Search API title/description/contents/link values must not be persisted.
DB_PATH=./data/accessibility.db
