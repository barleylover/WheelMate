# Required for Kakao Local API and Daum Search API.
KAKAO_REST_API_KEY=

# Required for Naver Search API.
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Optional public data/API keys. These are included in the PlayMCP config token
# and can be used with imported public accessibility datasets.
PUBLIC_DATA_SERVICE_KEY=
KTO_SERVICE_KEY=
CULTURE_BIGDATA_API_KEY=

# High-level feature flags.
USE_NAVER_SEARCH=true
USE_DAUM_SEARCH=true
USE_REVIEW_SEARCH=true

# Per-source feature flags.
USE_NAVER_BLOG=true
USE_NAVER_CAFE=true
USE_NAVER_WEB=true
USE_DAUM_BLOG=true
USE_DAUM_CAFE=true
USE_DAUM_WEB=true

# Runtime limits.
DEFAULT_RADIUS_M=1000
DEFAULT_LIMIT=5
MAX_PLACE_CANDIDATES=5
MAX_REVIEW_SEARCH_CALLS=60
SEARCH_RESULTS_PER_QUERY=3
SEARCH_TIMEOUT_MS=3500

# HTTP deployment settings.
PORT=8080
HOST=0.0.0.0
# Optional comma-separated host allow-list for deployed domains.
# Example: MCP_ALLOWED_HOSTS=your-service.example.com,localhost
MCP_ALLOWED_HOSTS=

# If the deployment platform cannot inject environment variables, run
# `pnpm run token:playmcp` locally and paste the generated secret into
# PlayMCP Key/token authentication instead. Do not commit that token.

# SQLite stores public/support data and geocoding cache only.
# Search API title/description/contents/link values must not be persisted.
DB_PATH=./data/accessibility.db
